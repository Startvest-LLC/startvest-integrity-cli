{
  "name": "@startvest/integrity-cli",
  "version": "1.4.0",
  "description": "CLI for The Integrity Framework. Run the v1.0 assertion suite against any repo, generate badge markdown, browse and submit listings to the Integrity Framework Directory. Pure ESM, zero runtime dependencies.",
  "type": "module",
  "bin": {
    "integrity": "./bin/integrity.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "manifests/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node test/runner.test.mjs && node test/badge.test.mjs"
  },
  "license": "MIT",
  "keywords": [
    "integrity-framework",
    "trust-framework",
    "compliance",
    "soc2-alternative",
    "ai-safety",
    "ai-trust",
    "sub-enterprise",
    "trust-artifact",
    "audit",
    "verifiability",
    "cli"
  ],
  "homepage": "https://theintegrityframework.org/framework/v1",
  "bugs": {
    "url": "https://github.com/Startvest-LLC/startvest-integrity-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Startvest-LLC/startvest-integrity-cli.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
